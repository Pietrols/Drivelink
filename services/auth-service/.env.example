# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://drivelink:drivelink_dev@localhost:5432/drivelink_db"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:drivelink_redis_dev@localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate secrets with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="REPLACE_WITH_STRONG_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_STRONG_SECRET"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── Email ─────────────────────────────────────────────────────────────────────
# In development OTPs are logged to console — no real emails sent
SENDGRID_API_KEY="SG.REPLACE_IN_PRODUCTION"
EMAIL_FROM="noreply@drivelink.app"

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:5173"