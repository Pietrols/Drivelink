generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  GUEST
  HOST
  ADMIN
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Pillar {
  RENTAL
  SERVICE
}

enum ListingStatus {
  PENDING_VERIFICATION
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  EN_ROUTE
  HANDED_OVER
  ACTIVE
  RETURN_PENDING
  RETURNED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum HandoverType {
  PICKUP
  RETURN
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  roles         Role[]
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  kycStatus     KycStatus @default(PENDING)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  listings              Listing[]
  bookingsAsGuest       Booking[]            @relation("GuestBookings")
  bookingsAsHost        Booking[]            @relation("HostBookings")
  bookingStatusChanges  BookingStatusHistory[]

  @@map("users")
}

model Listing {
  id          String        @id @default(uuid())
  hostId      String
  pillar      Pillar
  category    String
  subcategory String?
  title       String
  description String?
  pricePerDay Decimal       @db.Decimal(10, 2)
  location    String
  status      ListingStatus @default(PENDING_VERIFICATION)
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  host     User      @relation(fields: [hostId], references: [id])
  bookings Booking[]

  @@map("listings")
}

model Booking {
  id             String        @id @default(uuid())
  guestId        String
  hostId         String
  listingId      String
  startDate      DateTime
  endDate        DateTime
  totalDays      Int
  pricePerDay    Decimal       @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  status         BookingStatus @default(PENDING)
  pickupLocation String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  guest     User                   @relation("GuestBookings", fields: [guestId], references: [id])
  host      User                   @relation("HostBookings",  fields: [hostId],  references: [id])
  listing   Listing                @relation(fields: [listingId], references: [id])
  history   BookingStatusHistory[]
  handovers Handover[]

  @@map("bookings")
}

model BookingStatusHistory {
  id          String        @id @default(uuid())
  bookingId   String
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  changedById String
  reason      String?
  createdAt   DateTime      @default(now())

  booking   Booking @relation(fields: [bookingId],   references: [id])
  changedBy User    @relation(fields: [changedById], references: [id])

  @@map("booking_status_history")
}

model Handover {
  id               String       @id @default(uuid())
  bookingId        String
  type             HandoverType
  guestConfirmed   Boolean      @default(false)
  hostConfirmed    Boolean      @default(false)
  guestConfirmedAt DateTime?
  hostConfirmedAt  DateTime?
  createdAt        DateTime     @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("handovers")
}