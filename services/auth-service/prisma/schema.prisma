// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — DriveLink Auth Service
//
// After any change here run:
//   pnpm db:generate  → regenerates the TypeScript client
//   pnpm db:push      → applies changes to the database
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  DRIVER
  ADMIN
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── User ──────────────────────────────────────────────────────────────────────

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  phone        String? @unique
  passwordHash String  @map("password_hash")

  // A user can be CLIENT and DRIVER simultaneously
  roles Role[]

  // Verification
  emailVerified Boolean @default(false) @map("email_verified")
  phoneVerified Boolean @default(false) @map("phone_verified")

  // Gates booking activity
  kycStatus KycStatus @default(PENDING) @map("kyc_status")

  // Admin can flip this to suspend an account
  isActive Boolean @default(true) @map("is_active")

  // Driver delivery preferences
  canDeliver       Boolean @default(false) @map("can_deliver")
  deliveryRadiusKm Int?    @map("delivery_radius_km")

  // Audit fields — always present on every model
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("users")
}